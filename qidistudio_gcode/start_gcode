;===== PRINT_PHASE_INIT =====
SET_PRINT_STATS_INFO TOTAL_LAYER=[total_layer_count]
SET_PRINT_MAIN_STATUS MAIN_STATUS=print_start
M220 S100
M221 S100
SET_INPUT_SHAPER SHAPER_TYPE_X=mzv
SET_INPUT_SHAPER SHAPER_TYPE_Y=mzv
DISABLE_ALL_SENSOR
M1002 R1
M107
CLEAR_PAUSE
M140 S[bed_temperature_initial_layer_single]
M141 S[chamber_temperatures]
G29.0
_PRINT_START_HOME

;===== BOX_PREPAR =====
START_PRINT_FILAMENT_PREP EXTRUDER=[initial_no_support_extruder] HOTENDTEMP={nozzle_temperature_range_high[initial_tool]} PURGETEMP=[nozzle_temperature_initial_layer] BEDTEMP=[bed_temperature_initial_layer_single] CHAMBER=[chamber_temperatures]

;===== PRINT_START =====
; Turn on Polar cooler, comment out if you don't want this
M106 P4 S255
; Set total layer count for progress reporting.
SET_PRINT_STATS_INFO TOTAL_LAYER=[total_layer_count]
; Select the initial tool.
T[initial_tool]
; Set bed target temperature (do not wait).
M140 S[bed_temperature_initial_layer_single]
; Set nozzle target temperature (do not wait).
M104 S[nozzle_temperature_initial_layer]
; Set chamber target temperature (do not wait).
M141 S[chamber_temperatures]
; Move to the front-edge prime area.
G0 X195 Y1 F20000
; Move to a safe Z height before probing and priming.
G0 Z10 F480
; Pause 1 second to let temperatures and mechanics settle.
G4 P1000
; Take one probe sample at this location.
probe samples=1
; Switch to relative coordinates for local moves.
G91
; Lift 5 mm in relative mode.
G0 Z5 F480
; Return to absolute coordinates.
G90
; Move to the front-edge purge start point.
G1 X194 Y1 F20000
; Drop to the first-layer purge height.
G1 Z{initial_layer_print_height} F480
; Wait for nozzle to be fully back at first-layer temperature.
M109 S[nozzle_temperature_initial_layer]
; Run part cooling during the purge to help the strand release cleanly.
M106 S200
; Run an adaptive KAMP purge near the print area.
LINE_PURGE
; Turn the part cooling fan back off after the purge.
M106 S0
; Reset extruder position for the print proper.
G92 E0
; Restore absolute extrusion mode for sliced moves.
M82
; Mark printer status as actively printing after startup completes.
SET_PRINT_MAIN_STATUS MAIN_STATUS=printing
